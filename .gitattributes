# Default to auto-normalization and fall back to LF unless overridden
* text=auto
# Explicit LF endings for source & templates
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.tmpl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Preserve Windows-native scripts with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep patch files LF for tooling compatibility
*.patch text eol=lf

# Treat archive & binary assets as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.bz2 binary
