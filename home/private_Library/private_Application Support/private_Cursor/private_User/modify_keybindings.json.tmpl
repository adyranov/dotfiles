#!/usr/bin/env python3
"""Merge chezmoi-managed Cursor keybindings into the current keybindings.json (JSONC-safe)."""
import json, re, sys

def strip_jsonc(text):
    """Remove JS-style comments and trailing commas from JSONC."""
    result = []
    in_string = False
    escape = False
    i = 0
    while i < len(text):
        ch = text[i]
        if escape:
            result.append(ch)
            escape = False
            i += 1
            continue
        if ch == '\\' and in_string:
            result.append(ch)
            escape = True
            i += 1
            continue
        if ch == '"' and not in_string:
            in_string = True
            result.append(ch)
            i += 1
            continue
        if ch == '"' and in_string:
            in_string = False
            result.append(ch)
            i += 1
            continue
        if not in_string and ch == '/' and i + 1 < len(text):
            if text[i + 1] == '/':
                while i < len(text) and text[i] != '\n':
                    i += 1
                continue
            elif text[i + 1] == '*':
                i += 2
                while i + 1 < len(text) and not (text[i] == '*' and text[i + 1] == '/'):
                    i += 1
                i += 2
                continue
        result.append(ch)
        i += 1
    text = ''.join(result)
    # Remove trailing commas before } or ]
    text = re.sub(r',\s*([}\]])', r'\1', text)
    # Add missing commas between values and next property key
    text = re.sub(r'(true|false|null|\d+|"[^"]*"|\}|\])\s*\n(\s*")', r'\1,\n\2', text)
    return text

# Read current file from stdin
stdin_text = sys.stdin.read().strip()
current = []
if stdin_text:
    try:
        current = json.loads(strip_jsonc(stdin_text))
    except json.JSONDecodeError:
        current = []

# Managed keybindings
managed = [
    {"key": "cmd+i", "command": "composerMode.agent"},
]

# Merge: add managed bindings if not already present (match by key+command)
existing = {(b.get("key"), b.get("command")) for b in current}
for binding in managed:
    if (binding["key"], binding["command"]) not in existing:
        current.append(binding)

print(json.dumps(current, indent=2))
