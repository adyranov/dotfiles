#!/usr/bin/env python3
{{- $vscode := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "editors.vscode" "required" true) | mustFromJson }}
{{- $s := $vscode.settings }}
"""Merge chezmoi-managed VS Code settings into the current settings.json (JSONC-safe)."""
import json, re, sys

def strip_jsonc(text):
    """Remove JS-style comments and trailing commas from JSONC."""
    # Remove single-line comments (but not inside strings)
    result = []
    in_string = False
    escape = False
    i = 0
    while i < len(text):
        ch = text[i]
        if escape:
            result.append(ch)
            escape = False
            i += 1
            continue
        if ch == '\\' and in_string:
            result.append(ch)
            escape = True
            i += 1
            continue
        if ch == '"' and not in_string:
            in_string = True
            result.append(ch)
            i += 1
            continue
        if ch == '"' and in_string:
            in_string = False
            result.append(ch)
            i += 1
            continue
        if not in_string and ch == '/' and i + 1 < len(text):
            if text[i + 1] == '/':
                # Skip to end of line
                while i < len(text) and text[i] != '\n':
                    i += 1
                continue
            elif text[i + 1] == '*':
                # Skip to */
                i += 2
                while i + 1 < len(text) and not (text[i] == '*' and text[i + 1] == '/'):
                    i += 1
                i += 2
                continue
        result.append(ch)
        i += 1
    text = ''.join(result)
    # Remove trailing commas before } or ]
    text = re.sub(r',\s*([}\]])', r'\1', text)
    # Add missing commas between values and next property key
    text = re.sub(r'(true|false|null|\d+|"[^"]*"|\}|\])\s*\n(\s*")', r'\1,\n\2', text)
    return text

# Read current file from stdin
stdin_text = sys.stdin.read().strip()
current = {}
if stdin_text:
    try:
        current = json.loads(strip_jsonc(stdin_text))
    except json.JSONDecodeError:
        current = {}

# Managed settings (from chezmoi data)
managed = json.loads(r'''
{{- $font := $s.fontFamily }}
{{- $os := .chezmoi.os }}
{{- $managed := dict
  "workbench.colorTheme" $s.theme
  "workbench.iconTheme" $s.iconTheme
  "editor.fontFamily" (printf "%s, Menlo, Monaco, 'Courier New', monospace" $font)
  "editor.fontSize" $s.fontSize
  "editor.tabSize" $s.tabSize
  "editor.formatOnSave" $s.formatOnSave
  "editor.minimap.enabled" false
  "editor.renderWhitespace" "boundary"
  "editor.bracketPairColorization.enabled" true
  "editor.guides.bracketPairs" "active"
  "editor.linkedEditing" true
  "editor.stickyScroll.enabled" true
  "files.autoSave" "onFocusChange"
  "files.trimTrailingWhitespace" true
  "files.insertFinalNewline" true
  "files.trimFinalNewlines" true
  "terminal.integrated.fontFamily" $font
  "telemetry.telemetryLevel" "off"
  "extensions.autoUpdate" true
  "extensions.ignoreRecommendations" false
  "git.autofetch" true
  "git.confirmSync" false
  "git.enableSmartCommit" true
-}}
{{- if eq $os "darwin" -}}
{{-   $_ := set $managed "terminal.integrated.defaultProfile.osx" "zsh" -}}
{{- else -}}
{{-   $_ := set $managed "terminal.integrated.defaultProfile.linux" "zsh" -}}
{{- end }}
{{ $managed | toJson }}
''')

# Merge: managed keys overwrite, unmanaged keys preserved
current.update(managed)
print(json.dumps(current, indent=2))
