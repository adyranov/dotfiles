{{- if (lookPath "mise") -}}
CURRENT_SHELL=""

if [ -n "${ZSH_VERSION:-}" ]; then
  CURRENT_SHELL="zsh"
elif [ -n "${BASH_VERSION:-}" ]; then
  CURRENT_SHELL="bash"
fi

if [ -z "${CURRENT_SHELL}" ] && command -v ps >/dev/null 2>&1; then
  CURRENT_SHELL="$(ps -p $$ -o comm= | awk -F/ '{print $NF}' | sed 's/^-//')"
fi

if [ -n "${CURRENT_SHELL}" ]; then
  eval "$(mise activate "$CURRENT_SHELL")"
fi

unset CURRENT_SHELL
{{- end -}}
