{{- /* chezmoi:modify-template */ -}}
{{- /* Not .tmpl: chezmoi treats modify_*.tmpl as executable script templates. */ -}}
{{- $home := .chezmoi.homeDir -}}
{{- $current := dict -}}
{{- with index .chezmoi "stdin" -}}
{{-   $current = fromJson . -}}
{{- end -}}
{{- if not $current -}}{{- $current = dict -}}{{- end -}}
{{- $bash := dict "*" "ask" -}}
{{- range $tc, $perm := .ai.permissions.tools -}}
{{-   if or (eq $tc "core") (index $.toolchains $tc) -}}
{{-     range $verb := $perm.allow -}}
{{-       $_ := set $bash $verb "allow" -}}
{{-     end -}}
{{-     range $verb := $perm.deny -}}
{{-       $_ := set $bash $verb "deny" -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- $read := dict "*" "allow" -}}
{{- range .ai.permissions.paths.deny -}}
{{-   $_ := set $read . "deny" -}}
{{- end -}}
{{- $managed := dict
  "$schema" "https://opencode.ai/config.json"
  "autoupdate" false
  "instructions" (list (printf "%s/.config/agents/AGENTS.md" $home))
  "permission" (dict
    "bash" $bash
    "edit" "allow"
    "glob" "allow"
    "grep" "allow"
    "lsp" "allow"
    "read" $read
    "webfetch" "ask")
-}}
{{- $out := $current -}}
{{- range $k, $v := $managed -}}
{{-   $_ := set $out $k $v -}}
{{- end -}}
{{- $out | toPrettyJson -}}
