# Catppuccin Mocha — https://github.com/catppuccin/catppuccin
[color]
    ui = auto
    diff = auto
    status = auto
    branch = auto
    interactive = auto
[color "branch"]
    current = bold #89b4fa
    local = #f9e2af
    remote = #a6e3a1
[color "diff"]
    meta = bold #cba6f7
    frag = bold #f5c2e7
    old = bold #f38ba8
    new = bold #a6e3a1
[color "status"]
    added = #a6e3a1
    changed = #f9e2af
    untracked = #89dceb
