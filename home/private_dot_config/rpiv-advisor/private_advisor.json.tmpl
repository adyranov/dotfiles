{{- $pi := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.pi" "required" true) | mustFromJson -}}
{{- $route := index $pi.routes "heavy" -}}
{{- /* rpiv-advisor uses "provider:modelId" format (with colon separator) */ -}}
{{- $modelKey := printf "%s:%s" $route.provider $route.model -}}
{{- $effort := $route.thinking -}}
{
  "modelKey": "{{ $modelKey }}",
  "effort": "{{ $effort }}",
  "disabledForModels": [
    "{{ $modelKey }}"
  ]
}
