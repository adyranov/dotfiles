{{- $models := includeTemplate "base/helpers/load-section" (dict "root" . "section" "ai.models" "required" true) | mustFromJson -}}
{{- $pi := includeTemplate "base/helpers/load-section" (dict "root" . "section" "ai.agents.pi" "required" true) | mustFromJson -}}
{{- $defaults := index $models $models.default -}}
{{- $cfg := get (index $pi.profiles "core") "plannotator" | default dict -}}

{{- $planningCat := get $cfg "planning" | default "architect" -}}
{{- $executingCat := get $cfg "executing" | default "coder" -}}

{{- $planningRoute := get $models $planningCat | default dict -}}
{{- $executingRoute := get $models $executingCat | default dict -}}

{{- dict
  "defaults" (dict
    "model" (dict "provider" $defaults.provider "id" $defaults.model)
    "thinking" $defaults.thinking
  )
  "phases" (dict
    "planning" (dict
      "model" (dict "provider" ($planningRoute.provider | default $defaults.provider) "id" ($planningRoute.model | default $defaults.model))
      "thinking" ($planningRoute.thinking | default $defaults.thinking)
    )
    "executing" (dict
      "model" (dict "provider" ($executingRoute.provider | default $defaults.provider) "id" ($executingRoute.model | default $defaults.model))
      "thinking" ($executingRoute.thinking | default $defaults.thinking)
    )
  )
| toPrettyJson -}}
