{{- $pi := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.agents.pi" "required" true) | mustFromJson -}}
{{- $models := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.models" "required" true) | mustFromJson -}}
{{- $skillsData := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.skills" "required" true) | mustFromJson -}}
{{- $defaults := $models.default -}}
{{- $settings := $pi.settings -}}
{{- $packages := list -}}
{{- $skills := list -}}
{{- range $_, $skill := $skillsData -}}
{{-   range $sub := $skill.include -}}
{{-     $skills = append $skills (printf "../../agents/skills/%s" $sub) -}}
{{-   end -}}
{{- end -}}
{{- range $name := keys $pi.packages | sortAlpha -}}
{{-   $packages = append $packages (printf "npm:%s" $name) -}}
{{- end -}}
{{- $agentOverrides := includeTemplate "common/helpers/render-subagent-models" (dict "root" .) | mustFromJson -}}
{{- $piVersion := "" -}}
{{- if lookPath "mise" }}{{- $piVersion = output "mise" "current" "npm:@earendil-works/pi-coding-agent" | trim -}}{{- end -}}
{{- dict
  "bashMode" (dict
    "toggleShortcut" $settings.bash_mode.toggle_shortcut
    "transcriptMaxBytes" $settings.bash_mode.transcript_max_bytes
    "transcriptMaxLines" $settings.bash_mode.transcript_max_lines
  )
  "compaction" (dict "enabled" true "keepRecentTokens" 20000 "reserveTokens" 16384)
  "followUpMode" "all"
  "steeringMode" "all"
  "treeFilterMode" "no-tools"
  "defaultModel" $defaults.model
  "defaultProvider" $defaults.provider
  "defaultThinkingLevel" $defaults.thinking
  "enableInstallTelemetry" false
  "enabledModels" $models.enabled
  "lastChangelogVersion" $piVersion
  "npmCommand" (list "mise" "exec" "node@lts" "--" "npm")
  "packages" $packages
  "powerline" (dict
    "fixedEditor" $settings.powerline.fixed_editor
    "mouseScroll" $settings.powerline.mouse_scroll
    "preset" $settings.powerline.preset
  )
  "quietStartup" true
  "retry" (dict "baseDelayMs" 2000 "enabled" true "maxRetries" 3)
  "skills" $skills
  "subagents" (dict "agentOverrides" $agentOverrides)
  "theme" $settings.theme
  "warnings" (dict "anthropicExtraUsage" true)
| toPrettyJson -}}
