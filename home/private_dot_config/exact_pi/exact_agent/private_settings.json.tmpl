{{- $pi := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.pi" "required" true) | mustFromJson -}}
{{- $skillsData := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.skills" "required" true) | mustFromJson -}}
{{- $defaults := $pi.defaults -}}
{{- $routes := $pi.routes -}}
{{- $packages := list -}}
{{- $skills := list -}}
{{- range $_, $skill := $skillsData -}}
{{-   range $sub := $skill.include -}}
{{-     $skills = append $skills (printf "../../agents/skills/%s" $sub) -}}
{{-   end -}}
{{- end -}}
{{- range $name := keys $pi.packages | sortAlpha -}}
{{-   $packages = append $packages (printf "npm:%s" $name) -}}
{{- end -}}
{{- /* Build agentOverrides: map each subagent to its routing category's model */ -}}
{{- $agentOverrides := dict -}}
{{- range $category, $agents := $pi.subagents -}}
{{-   $route := index $routes $category -}}
{{-   $model := $route.model -}}
{{-   if hasKey $route "provider" -}}
{{-     $model = printf "%s/%s" $route.provider $route.model -}}
{{-   end -}}
{{-   $override := dict "model" $model "thinking" $route.thinking -}}
{{-   range $agent := $agents -}}
{{-     $agentOverrides = merge $agentOverrides (dict $agent $override) -}}
{{-   end -}}
{{- end -}}
{{- $piVersion := output "mise" "current" "npm:@earendil-works/pi-coding-agent" | trim -}}
{{- dict
  "compaction" (dict "enabled" true "keepRecentTokens" 20000 "reserveTokens" 16384)
  "defaultModel" $defaults.model
  "defaultProvider" $defaults.provider
  "defaultThinkingLevel" $defaults.thinking_level
  "enableInstallTelemetry" false
  "enabledModels" $defaults.enabled_models
  "lastChangelogVersion" $piVersion
  "npmCommand" (list "mise" "exec" "node@lts" "--" "npm")
  "observational-memory" (dict "observeAfterTokens" 10000 "reflectAfterTokens" 20000 "compactAfterTokens" 81000 "observationsPoolMaxTokens" 20000 "observationsPoolTargetTokens" 10000 "agentMaxTurns" 16)
  "packages" $packages
  "quietStartup" true
  "retry" (dict "baseDelayMs" 2000 "enabled" true "maxRetries" 3)
  "skills" $skills
  "subagents" (dict "agentOverrides" $agentOverrides)
  "theme" $pi.settings.theme
  "warnings" (dict "anthropicExtraUsage" true)
| toPrettyJson -}}
