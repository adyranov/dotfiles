{{- /* chezmoi:modify-template */ -}}
{{- /* Not .tmpl: chezmoi treats modify_*.tmpl as executable script templates. */ -}}
{{- $current := dict -}}
{{- with index .chezmoi "stdin" -}}
{{-   $current = fromJson . -}}
{{- end -}}
{{- if not $current -}}{{- $current = dict -}}{{- end -}}
{{- $packages := list -}}
{{- $skills := list -}}
{{- range $_, $skill := .ai.skills -}}
{{-   range $sub := $skill.include -}}
{{-     $skills = append $skills (printf "../../agents/skills/%s" $sub) -}}
{{-   end -}}
{{- end -}}
{{- /* Preserve user-added packages, skip chezmoi-managed entries */ -}}
{{- $managedRepos := list -}}
{{- range $_, $s := .ai.skills -}}
{{-   $managedRepos = append $managedRepos $s.repo -}}
{{- end -}}
{{- range $pkg := default (list) (index $current "packages") -}}
{{-   $skip := hasPrefix "../../agents/" $pkg -}}
{{-   if not $skip -}}
{{-     range $repo := $managedRepos -}}
{{-       $repoParts := splitList "@" $repo -}}
{{-       $repoBase := index $repoParts 0 -}}
{{-       $repoRef := "" -}}
{{-       if gt (len $repoParts) 1 -}}{{- $repoRef = index $repoParts 1 -}}{{- end -}}
{{-       if or (eq $pkg (printf "git:github.com/%s" $repoBase)) (and $repoRef (eq $pkg (printf "git:github.com/%s@%s" $repoBase $repoRef))) (hasPrefix (printf "git:github.com/%s@" $repoBase) $pkg) -}}
{{-         $skip = true -}}
{{-       end -}}
{{-     end -}}
{{-   end -}}
{{-   if and (not $skip) (not (has $pkg $packages)) -}}
{{-     $packages = append $packages $pkg -}}
{{-   end -}}
{{- end -}}
{{- /* Preserve user-added skills */ -}}
{{- range $sk := default (list) (index $current "skills") -}}
{{-   if not (has $sk $skills) -}}
{{-     $skills = append $skills $sk -}}
{{-   end -}}
{{- end -}}
{{- $managed := dict
  "compaction" (dict "enabled" true "keepRecentTokens" 20000 "reserveTokens" 16384)
  "defaultThinkingLevel" "medium"
  "enableInstallTelemetry" false
  "enabledModels" (list "claude-*" "gemini-2*" "gpt-5*")
  "npmCommand" (list "mise" "exec" "node@lts" "--" "npm")
  "packages" $packages
  "quietStartup" true
  "retry" (dict "baseDelayMs" 2000 "enabled" true "maxRetries" 3)
  "skills" $skills
  "theme" "dark"
  "warnings" (dict "anthropicExtraUsage" true)
-}}
{{- $out := $current -}}
{{- range $k, $v := $managed -}}
{{-   $_ := set $out $k $v -}}
{{- end -}}
{{- $out | toPrettyJson -}}
