{{- /* chezmoi:modify-template */ -}}
{{- $rawStdin := get .chezmoi "stdin" | default "" | trim -}}
{{- $baseSource := `{"schemaVersion": 1, "filesystem": {"allowWrite": []}, "network": {"rules": []}}` -}}
{{- if ne $rawStdin "" -}}
{{-   $baseSource = $rawStdin -}}
{{- end -}}
{{- $base := $baseSource | fromJsonc -}}
{{- /* Prune wildcard (*) destinations from existing learned rules.
    Keep other learned/bundled rules so greywall profile drift checks stay stable. */ -}}
{{- $baseRules := dig "network" "rules" (list) $base -}}
{{- $cleanRules := list -}}
{{- range $rule := $baseRules -}}
{{-   if not (contains "*" ($rule.destination | toString)) -}}
{{-     $cleanRules = append $cleanRules $rule -}}
{{-   end -}}
{{- end -}}
{{- $base = setValueAtPath "network.rules" $cleanRules $base -}}
{{- $pi := includeTemplate "base/helpers/load-section" (dict "root" . "section" "ai.agents.pi" "required" true) | mustFromJson -}}
{{- $sandbox := $pi.sandbox | default dict -}}
{{- $sandboxPaths := $sandbox.paths | default dict -}}
{{- $allowWriteAdditions := index $sandboxPaths "allow_write" | default list -}}
{{- $allowReadAdditions := index $sandboxPaths "allow_read" | default list -}}
{{- $networkRuleAdditions := list -}}
{{- range $rule := dig "network" "allow" (list) $sandbox -}}
{{-   $networkRuleAdditions = append $networkRuleAdditions (dict
        "destination" $rule.host
        "port" ($rule.port | toString)
        "action" "allow"
      ) -}}
{{- end -}}
{{- $base
  | setValueAtPath "filesystem.allowWrite" (concat (dig "filesystem" "allowWrite" (list) $base) $allowWriteAdditions | uniq)
  | setValueAtPath "filesystem.allowRead" (concat (dig "filesystem" "allowRead" (list) $base) $allowReadAdditions | uniq)
  | setValueAtPath "network.rules" (concat (dig "network" "rules" (list) $base) $networkRuleAdditions | uniq)
  | toPrettyJson
-}}
