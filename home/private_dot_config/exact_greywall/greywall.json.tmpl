{{- /* Greywall kernel sandbox config — derived from shared AI path policy and package command policy.
  Reads are project-scoped by default; sensitive paths are denied explicitly. */ -}}
{{- $commandPermissions := includeTemplate "common/helpers/load-package-permissions" (dict "root" .) | mustFromJson -}}
{{- $pathPermissions := includeTemplate "common/helpers/load-ai-path-permissions" (dict "root" .) | mustFromJson -}}
{{- $denyPaths := $pathPermissions.deny -}}
{{- $cmdDeny := $commandPermissions.deny -}}
{{- $allowRead := concat (list ".") $pathPermissions.allow_read | uniq | sortAlpha -}}
{{- $allowWrite := concat (list ".") $pathPermissions.allow_write | uniq | sortAlpha -}}
{{- $network := dict
  "proxyUrl" "socks5://localhost:43052"
  "httpProxyUrl" "http://localhost:43051"
  "dnsAddr" "localhost:43053"
  "rules" list
-}}
{{- $ssh := dict
  "allowedHosts" (list "github.com")
  "allowedCommands" (list "git-upload-pack")
  "deniedCommands" (list "git-receive-pack" "git-upload-archive" "scp" "sftp" "rsync" "sh" "bash" "zsh" "sudo" "curl" "wget" "nc" "ncat")
  "inheritDeny" true
-}}
{{- dict
  "network" $network
  "filesystem" (dict "defaultDenyRead" true "denyRead" $denyPaths "denyWrite" $denyPaths "allowRead" $allowRead "allowWrite" $allowWrite)
  "command" (dict "deny" $cmdDeny "useDefaults" true)
  "ssh" $ssh
| toPrettyJson }}
