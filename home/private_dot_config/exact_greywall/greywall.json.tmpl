{{- /* Greywall kernel sandbox config — derived from shared AI path policy and package command policy.
  Level 1 (sandbox): deny-all default; only allow-lists needed.
  Level 2 (agent permissions): handled by pi-permission-system / opencode.json permission object. */ -}}
{{- $commandPermissions := includeTemplate "base/packages/collect-policies" (dict "root" .) | mustFromJson -}}
{{- $sandbox := (includeTemplate "base/helpers/load-section" (dict "root" . "section" "ai.permissions.sandbox" "required" true) | mustFromJson) -}}
{{- $cmdDeny := $commandPermissions.deny -}}
{{- $allowRead := concat (list ".") (index $sandbox "allow_read" | default list) | uniq | sortAlpha -}}
{{- $allowWrite := concat (list ".") (index $sandbox "allow_write" | default list) | uniq | sortAlpha -}}
{{- $greyproxy := (includeTemplate "base/helpers/load-section" (dict "root" . "section" "ai.sandbox.greyproxy" "required" true) | mustFromJson) -}}
{{- $networkPolicy := (includeTemplate "base/helpers/load-section" (dict "root" . "section" "ai.permissions.network" "required" false) | mustFromJson) -}}
{{- $networkRules := list -}}
{{- range (index $networkPolicy "allow" | default list) -}}
  {{- $networkRules = append $networkRules (dict "destination" .host "port" (toString .port) "action" "allow") -}}
{{- end -}}
{{- $network := dict
  "proxyUrl" (printf "socks5://localhost:%v" $greyproxy.socks)
  "httpProxyUrl" (printf "http://localhost:%v" $greyproxy.http)
  "dnsAddr" (printf "localhost:%v" $greyproxy.dns)
  "rules" $networkRules
-}}
{{- $ssh := dict
  "allowedHosts" (list "github.com")
  "allowedCommands" (list "git-upload-pack")
  "deniedCommands" (list "git-receive-pack" "git-upload-archive" "scp" "sftp" "rsync" "sh" "bash" "zsh" "sudo" "curl" "wget" "nc" "ncat")
  "inheritDeny" true
-}}
{{- dict
  "network" $network
  "filesystem" (dict "defaultDenyRead" true "allowRead" $allowRead "allowWrite" $allowWrite)
  "command" (dict "deny" $cmdDeny "useDefaults" true)
  "ssh" $ssh
| toPrettyJson }}
