{{- /* Greywall kernel sandbox config — derived from ai.permissions in ai.toml.
  defaultDenyRead: true; allowRead permits only the current working directory. */ -}}
{{- $denyRead := .ai.permissions.paths.deny -}}
{{- $cmdDeny := list -}}
{{- range $tc, $perm := .ai.permissions.tools -}}
{{-   if or (eq $tc "core") (index $.toolchains $tc) -}}
{{-     range $verb := $perm.deny -}}
{{-       $cmdDeny = append $cmdDeny $verb -}}
{{-     end -}}
{{-   end -}}
{{- end -}}
{{- $allowRead := list "." -}}
{{- $allowWrite := list "." -}}
{{- dict
  "filesystem" (dict "defaultDenyRead" true "denyRead" $denyRead "allowRead" $allowRead "allowWrite" $allowWrite)
  "command" (dict "deny" $cmdDeny "useDefaults" true)
| toPrettyJson }}
