# bats test_tags=toolchain:pi,kind:permission
@test "pi permission-system config renders secure runtime defaults" {
  assert_file_exists "$HOME/.config/pi/agent/extensions/pi-permission-system/config.json"
  run jq -e '
    .debugLog == false and
    .permissionReviewLog == true and
    .yoloMode == false and
    .toolInputPreviewMaxLength == 400 and
    .toolTextSummaryMaxLength == 120 and
    (.piInfrastructureReadPaths | length) > 0 and
    (.piInfrastructureReadPaths | index("~/.config/pi/**") != null) and
    (.piInfrastructureReadPaths | index("~/.config/agents/**") != null) and
    (.piInfrastructureReadPaths | index("~/.config/greywall/**") != null) and
    (.piInfrastructureReadPaths | index("**/node_modules/@earendil-works/pi-coding-agent/**") != null) and
    .permission["*"] == "ask" and
    .permission.external_directory == "allow" and
    .permission.write == "allow" and
    .permission.edit == "allow" and
    .permission.task == "allow"
  ' "$HOME/.config/pi/agent/extensions/pi-permission-system/config.json"
  assert_success
}

