# bats test_tags=kind:greywall
@test "greywall.json is deployed from ai permissions" {
  assert_file_exists "{{ $greywallDir }}/greywall.json"
  run jq -e '
    .filesystem.defaultDenyRead == true and
    .filesystem.allowRead == [".", "~/.config/certificates/ca-bundle.pem", "~/.local/share/engram/**"] and
    .filesystem.allowWrite == [".", "~/.local/share/engram/**"] and
    (.filesystem.denyRead | index("**/.env") != null) and
    (.filesystem.denyRead | index("~/.ssh/**") != null) and
    (.filesystem.denyWrite | index("**/.env") != null) and
    (.filesystem.denyWrite | index("~/.ssh/**") != null) and
    (.command.allow | not) and
    (.command.deny | index("git * reset --hard *") != null) and
    (.command.deny | index("docker * system prune *") != null) and
    .network.proxyUrl == "socks5://localhost:43052" and
    .network.httpProxyUrl == "http://localhost:43051" and
    .network.dnsAddr == "localhost:43053" and
    (.network.rules // []) == [] and
    .ssh.allowedHosts == ["github.com"] and
    .ssh.allowedCommands == ["git-upload-pack"] and
    (.ssh.deniedCommands | index("git-receive-pack") != null) and
    (.ssh.deniedCommands | index("scp") != null) and
    .ssh.inheritDeny == true
  ' "{{ $greywallDir }}/greywall.json"
  assert_success
}

# bats test_tags=kind:greywall
@test "greywall global policy has no broad network allow" {
  assert_file_exists "{{ $greywallDir }}/greywall.json"
  run jq -e '((.network.rules // []) | all(.action != "allow" or .destination != "*"))' "{{ $greywallDir }}/greywall.json"
  assert_success
}

