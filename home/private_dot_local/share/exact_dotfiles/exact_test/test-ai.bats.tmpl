# bats test_tags=toolchain:pi,kind:permission
@test "pi permission-system config renders bash allow and deny rules" {
  local cfg="$HOME/.config/pi/agent/extensions/pi-permission-system/config.json"

  # Helper: check a single bash permission rule
  assert_bash_rule() {
    local pattern=$1 expected=$2
    run jq -r --arg p "$pattern" '.permission.bash[$p] // "null"' "$cfg"
    if [ "$output" != "$expected" ]; then
      fail "Rule '$pattern': expected '$expected', got '$output'"
    fi
  }

  # Helper: check a single bash permission negative rule
  assert_bash_rule_not() {
    local pattern=$1 forbidden=$2
    run jq -r --arg p "$pattern" '.permission.bash[$p] // "null"' "$cfg"
    if [ "$output" = "$forbidden" ]; then
      fail "Rule '$pattern': must not be '$forbidden'"
    fi
  }

  # Core rules (always present via packages.base.core)
  assert_bash_rule '*' 'ask'
  assert_bash_rule_not 'git *' 'allow'
  assert_bash_rule_not 'docker *' 'allow'
  assert_bash_rule_not 'kubectl *' 'allow'
  assert_bash_rule_not 'aws *' 'allow'
  assert_bash_rule_not 'npm *' 'allow'
  assert_bash_rule_not 'curl *' 'allow'
  assert_bash_rule 'git status *' 'allow'
  assert_bash_rule 'git diff *' 'allow'
  assert_bash_rule 'chezmoi diff *' 'allow'
  assert_bash_rule 'git commit *' 'ask'
  assert_bash_rule 'git push *' 'ask'
  assert_bash_rule 'mise *' 'ask'
  assert_bash_rule 'curl *' 'ask'
  assert_bash_rule 'wget *' 'ask'
  assert_bash_rule 'git * reset --hard *' 'deny'
  assert_bash_rule 'git * push --force*' 'deny'
  assert_bash_rule 'rm *' 'ask'
  assert_bash_rule 'rm -rf /*' 'deny'
  assert_bash_rule 'sudo *' 'deny'
{{- if .toolchains.cloud }}
  # Cloud toolchain rules
  assert_bash_rule 'aws sts get-caller-identity *' 'allow'
  assert_bash_rule 'aws * s3 rm *' 'deny'
{{- end }}
{{- if .toolchains.docker }}
  # Docker toolchain rules
  assert_bash_rule 'docker ps *' 'allow'
  assert_bash_rule 'docker images *' 'allow'
  assert_bash_rule 'docker run *' 'ask'
  assert_bash_rule 'docker * system prune *' 'deny'
  assert_bash_rule 'docker * run * --privileged *' 'deny'
{{- end }}
{{- if .toolchains.iac }}
  # IAC toolchain rules
  assert_bash_rule 'tofu plan *' 'allow'
  assert_bash_rule 'tofu *' 'ask'
  assert_bash_rule 'tofu * destroy *' 'deny'
{{- end }}
{{- if .toolchains.kubernetes }}
  # Kubernetes toolchain rules
  assert_bash_rule 'kubectl * get *' 'allow'
  assert_bash_rule 'kubectl * describe *' 'allow'
  assert_bash_rule 'helm list *' 'allow'
  assert_bash_rule 'kubectl apply *' 'ask'
  assert_bash_rule 'kubectl * delete *' 'deny'
  assert_bash_rule 'helm * upgrade *' 'deny'
{{- end }}
{{- if .toolchains.node }}
  # Node toolchain rules
  assert_bash_rule 'npm *' 'ask'
  assert_bash_rule 'pnpm *' 'ask'
  assert_bash_rule 'yarn *' 'ask'
  assert_bash_rule 'bun *' 'ask'
{{- end }}
{{- if .toolchains.python }}
  # Python toolchain rules
  assert_bash_rule 'python *' 'ask'
  assert_bash_rule 'uv *' 'ask'
{{- end }}
}

