# bats test_tags=toolchain:pi,kind:config
@test "pi factory profile symlinks resolve to agent config" {
  local profile="factory"
  run readlink -f "$HOME/.config/pi/profiles/$profile/AGENTS.md"
  assert_success
  assert_output "$HOME/.config/agents/AGENTS.md"
  run readlink -f "$HOME/.config/pi/profiles/$profile/auth.json"
  assert_success
  assert_output "$HOME/.config/pi/agent/auth.json"
  run readlink -f "$HOME/.config/pi/profiles/$profile/models.json"
  assert_success
  assert_output "$HOME/.config/pi/agent/models.json"
  run readlink -f "$HOME/.config/pi/profiles/$profile/mcp.json"
  assert_success
  assert_output "$HOME/.config/pi/agent/mcp.json"
  run readlink -f "$HOME/.config/pi/profiles/$profile/extensions/pi-permission-system/config.json"
  assert_success
  assert_output "$HOME/.config/pi/agent/extensions/pi-permission-system/config.json"
  run readlink -f "$HOME/.config/pi/profiles/$profile/plannotator.json"
  assert_success
  assert_output "$HOME/.config/pi/agent/plannotator.json"
}

