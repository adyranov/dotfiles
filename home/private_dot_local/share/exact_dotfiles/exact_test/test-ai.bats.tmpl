# bats test_tags=toolchain:pi,kind:permission
@test "pi settings.json disables install telemetry" {
  run grep -F '"enableInstallTelemetry": false' "$HOME/.config/pi/agent/settings.json"
  assert_success
}

# bats test_tags=toolchain:pi,kind:model
@test "pi settings.json has no subagent overrides in default core profile" {
  assert_file_exists "$HOME/.config/pi/agent/settings.json"
  run jq -e '.subagents.agentOverrides | length == 0' "$HOME/.config/pi/agent/settings.json"
  assert_success
}

# bats test_tags=toolchain:pi,kind:packages
@test "pi settings.json contains core packages only" {
  assert_file_exists "$HOME/.config/pi/agent/settings.json"
{{- $core := index $pi.profiles "core" }}
{{- range $name := $core.packages }}
  run grep -F '"npm:{{ $name }}"' "$HOME/.config/pi/agent/settings.json"
  assert_success
{{- end }}
  run grep -F '"npm:@juicesharp/rpiv-pi"' "$HOME/.config/pi/agent/settings.json"
  assert_failure
}

# bats test_tags=toolchain:pi,kind:config
@test "pi settings.json renders powerline footer config" {
  run jq -e '
    .powerline.preset == "{{ $pi.settings.powerline.preset }}" and
    .powerline.fixedEditor == {{ $pi.settings.powerline.fixed_editor }} and
    .powerline.mouseScroll == {{ $pi.settings.powerline.mouse_scroll }} and
    .bashMode.toggleShortcut == "{{ $pi.settings.bash_mode.toggle_shortcut }}" and
    .bashMode.transcriptMaxLines == {{ $pi.settings.bash_mode.transcript_max_lines }} and
    .bashMode.transcriptMaxBytes == {{ $pi.settings.bash_mode.transcript_max_bytes }}
  ' "$HOME/.config/pi/agent/settings.json"
  assert_success
}

# bats test_tags=toolchain:pi,kind:config
@test "pi settings.json uses lightweight compaction for core" {
  run jq -e '
    .compaction.keepRecentTokens == 8000 and
    .compaction.reserveTokens == 8192
  ' "$HOME/.config/pi/agent/settings.json"
  assert_success
}

# bats test_tags=toolchain:pi,kind:config
@test "pi settings.json loads only core skills" {
  run jq -e '.skills | length == 1' "$HOME/.config/pi/agent/settings.json"
  assert_success
  run jq -e '.skills | index("../../agents/skills/karpathy-guidelines") != null' "$HOME/.config/pi/agent/settings.json"
  assert_success
}

