{{- includeTemplate "base/headers/script" (dict "root" .) -}}

{{ $ca_bundle := joinPath .host.home ".config/certificates/ca-bundle.pem" -}}
{{ $greyproxy_ca := joinPath .host.home ".local/share/greyproxy/ca-cert.pem" -}}
# Greyproxy CA hash: {{ if stat $greyproxy_ca }}{{ include $greyproxy_ca | sha256sum }}{{ else }}missing{{ end }}

CA_BUNDLE="{{ $ca_bundle }}"
GREYPROXY_CA="{{ $greyproxy_ca }}"
KEYCHAINS=(
  "/System/Library/Keychains/SystemRootCertificates.keychain"
  "/Library/Keychains/System.keychain"
)

echo "🔐 Setting up CA bundle..."

for tool in security openssl; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "  ❌ Required tool '$tool' not found, skipping." >&2
    exit 0
  fi
done

# Collect SHA-1 fingerprints of explicitly distrusted certificates
getDeniedFingerprints() {
  local tmpdir
  tmpdir="$(mktemp -d)"
  local denied_file="$tmpdir/denied.txt"
  : > "$denied_file"

  for domain in user admin; do
    local plist="$tmpdir/${domain}.plist"
    if security trust-settings-export -d "$domain" "$plist" 2>/dev/null; then
      /usr/libexec/PlistBuddy -c "Print :trustList" "$plist" 2>/dev/null | \
        awk '
          /^    [A-F0-9]/ { current_hash = $1 }
          /kSecTrustSettingsResult/ { getline; if ($NF == 3) print current_hash }
        ' >> "$denied_file" 2>/dev/null || true
    fi
  done

  sort -u "$denied_file"
  rm -rf "$tmpdir"
}

denied_fps="$(getDeniedFingerprints)"

outfile="$(mktemp)"
trap 'rm -f "$outfile"' EXIT

echo "📦 Extracting trusted certificates from system keychains..."
echo ""

trusted_count=0
denied_count=0
expired_count=0

for keychain in "${KEYCHAINS[@]}"; do
  if [ ! -f "$keychain" ]; then
    printf "  ⚠️  Keychain not found, skipping: %s\n" "$keychain" >&2
    continue
  fi

  tmpdir="$(mktemp -d)"

  security find-certificate -a -p "$keychain" > "$tmpdir/all.pem" 2>/dev/null

  cert_num=0
  current_cert=""
  while IFS= read -r line; do
    if [ "$line" = "-----BEGIN CERTIFICATE-----" ]; then
      current_cert="$line"$'\n'
    elif [ "$line" = "-----END CERTIFICATE-----" ]; then
      current_cert="$current_cert$line"
      printf "%s\n" "$current_cert" > "$tmpdir/cert-$cert_num.pem"
      cert_num=$((cert_num + 1))
      current_cert=""
    elif [ -n "$current_cert" ]; then
      current_cert="$current_cert$line"$'\n'
    fi
  done < "$tmpdir/all.pem"

  for ((i = 0; i < cert_num; i++)); do
    local_cert="$tmpdir/cert-$i.pem"

    subject="$(openssl x509 -in "$local_cert" -noout -subject 2>/dev/null | sed 's/^subject=//')"
    sha1="$(openssl x509 -in "$local_cert" -noout -fingerprint -sha1 2>/dev/null | awk -F= '{print $2}' | tr -d ':')"

    # Skip explicitly denied certs
    if [ -n "$denied_fps" ] && echo "$denied_fps" | grep -qi "$sha1" 2>/dev/null; then
      denied_count=$((denied_count + 1))
      printf "  [%03d] ❌ Denied   %s\n" "$((trusted_count + denied_count + expired_count))" "$subject"
      continue
    fi

    # Skip expired certs
    if ! openssl x509 -in "$local_cert" -noout -checkend 0 >/dev/null 2>&1; then
      expired_count=$((expired_count + 1))
      printf "  [%03d] ⚠️  Expired  %s\n" "$((trusted_count + denied_count + expired_count))" "$subject"
      continue
    fi

    trusted_count=$((trusted_count + 1))
    printf "  [%03d] ✅ Trusted  %s\n" "$((trusted_count + denied_count + expired_count))" "$subject"
    cat "$local_cert" >> "$outfile"
    echo "" >> "$outfile"
  done

  rm -rf "$tmpdir"
done

greyproxy_count=0
if [ -s "$GREYPROXY_CA" ]; then
  echo "➕ Appending Greyproxy CA: $GREYPROXY_CA"
  cat "$GREYPROXY_CA" >> "$outfile"
  echo "" >> "$outfile"
  greyproxy_count=1
else
  echo "ℹ️  Greyproxy CA not found, skipping: $GREYPROXY_CA"
fi

echo ""

mkdir -p "$(dirname "$CA_BUNDLE")"

# Only update the file if content changed
if [ -f "$CA_BUNDLE" ] && cmp -s "$outfile" "$CA_BUNDLE"; then
  echo "✅ $CA_BUNDLE is already up to date ($trusted_count system certificate(s), $greyproxy_count Greyproxy certificate(s), $denied_count denied, $expired_count expired)"
else
  mv "$outfile" "$CA_BUNDLE"
  trap - EXIT
  echo "✅ Wrote $trusted_count system certificate(s) and $greyproxy_count Greyproxy certificate(s) to $CA_BUNDLE ($denied_count denied, $expired_count expired)"
fi

echo "✅ CA bundle setup complete."
