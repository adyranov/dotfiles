{{- if .toolchains.pi -}}
{{- includeTemplate "common/headers/after" . -}}
{{- $piPackages := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "ai.agents.pi.packages" "required" true) | mustFromJson -}}

# Hash: {{ keys $piPackages | sortAlpha | join "," | sha256sum }}

PI_NPM="${HOME}/.config/pi/agent/npm"

if [ ! -d "$PI_NPM/node_modules" ]; then
  exit 0
fi

echo "🧹 Reconciling pi packages..."

# Generate a package.json with only the declared packages as dependencies.
# npm prune will remove anything not reachable from this dependency tree.
cat > "$PI_NPM/package.json" <<'EOF'
{
  "name": "pi-agent-packages",
  "private": true,
  "dependencies": {
{{- $pkgs := keys $piPackages | sortAlpha -}}
{{- range $i, $name := $pkgs }}
    "{{ $name }}": "*"{{ if ne $i (sub (len $pkgs) 1) }},{{ end }}
{{- end }}
  }
}
EOF

# Let npm resolve the dependency tree and prune anything not reachable.
# --legacy-peer-deps: pi extensions have loose peer deps that conflict during
# strict resolution; pi handles peer satisfaction at runtime.
npm prune --prefix "$PI_NPM" --legacy-peer-deps --silent 2>/dev/null && \
  echo "  ✅ Pi packages reconciled." || \
  echo "  ⚠️  npm prune failed; manual cleanup may be needed."
{{- end -}}
