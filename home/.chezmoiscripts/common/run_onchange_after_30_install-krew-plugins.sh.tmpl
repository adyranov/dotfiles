{{- if .toolchains.kubernetes -}}
{{- includeTemplate "base/headers/script" (dict "root" .) -}}

KREW_PLUGINS=(
{{- $packages := splitList " " (includeTemplate "base/packages/collect-packages" (dict "root" . "manager" "krew" "format" "install")) -}}
{{- range $pkg := $packages -}}
{{- if ne $pkg "" }}
  "{{ $pkg }}"
{{- end -}}
{{- end }}
)

echo "☸️  Ensuring krew and plugins..."

if [[ ! -e $KREW_ROOT/bin/kubectl-krew ]]; then
    echo "  ↳ Installing krew (kubectl plugin manager)..."
    (
    cd "$(mktemp -d)" &&
    OS="$(uname | tr '[:upper:]' '[:lower:]')" &&
    ARCH="$(uname -m | sed -e 's/x86_64/amd64/' -e 's/\(arm\)\(64\)\?.*/\1\2/' -e 's/aarch64$/arm64/')" &&
    KREW="krew-${OS}_${ARCH}" &&
    curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/${KREW}.tar.gz" &&
    tar zxvf "${KREW}.tar.gz" &&
    ./"${KREW}" install krew >/dev/null 2>&1
    )
    echo "  ✅ krew installed."
fi

$KREW_ROOT/bin/kubectl-krew version >/dev/null 2>&1 || true
echo "  🔄 Updating krew indexes..."
$KREW_ROOT/bin/kubectl-krew update 2>/dev/null
$KREW_ROOT/bin/kubectl-krew upgrade 2>/dev/null

echo "  🔌 Ensuring plugins..."
for plugin in "${KREW_PLUGINS[@]}"; do
    if ! $KREW_ROOT/bin/kubectl-krew list | grep -q "^$plugin$"; then
        echo "    ↳ Installing: $plugin"
        $KREW_ROOT/bin/kubectl-krew install "$plugin" >/dev/null 2>&1
    else
        echo "    ✅ Already installed: $plugin"
    fi
done

echo "  🗑️ Removing stale plugins..."
installed=$($KREW_ROOT/bin/kubectl-krew list 2>/dev/null | tail -n +2 | awk '{print $1}')
for plugin in $installed; do
    [ "$plugin" = "krew" ] && continue
    found=false
    for wanted in "${KREW_PLUGINS[@]}"; do
        if [ "$plugin" = "$wanted" ]; then
            found=true
            break
        fi
    done
    if [ "$found" = "false" ]; then
        echo "    ↳ Removing: $plugin"
        $KREW_ROOT/bin/kubectl-krew uninstall "$plugin" >/dev/null 2>&1 || true
    fi
done

echo "✅ krew and plugins ensured."
{{- end -}}
