{{- includeTemplate "base/headers/script" (dict "root" .) -}}

echo "🐚 Configuring login shell..."

for cand in "/usr/local/bin/zsh" "/opt/homebrew/bin/zsh" "/usr/bin/zsh" "/bin/zsh"; do
  if [ -x "$cand" ]; then
    zsh_path="$cand"
    break
  fi
done

if [ -z "${zsh_path:-}" ]; then
  echo "❌ No zsh found, exiting."
  exit 0
fi

if [ "$SHELL" = "$zsh_path" ]; then
  echo "  ✅ Login shell is already $zsh_path."
  exit 0
fi

echo "  🔍 Checking if $zsh_path is listed in /etc/shells..."
if ! grep -qx "$zsh_path" /etc/shells 2>/dev/null; then
  {{ if not .host.restricted -}}
  echo "  ➕ Adding $zsh_path to /etc/shells (requires sudo)..."
  echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null || true
  {{ else -}}
  echo "  ⚠️  $zsh_path not in /etc/shells, add manually." >&2
  {{ end -}}
else
  echo "  ✅ $zsh_path already listed in /etc/shells."
fi

{{ if not .host.restricted -}}
echo "  🔄 Changing login shell to $zsh_path..."
if sudo chsh -s "$zsh_path" "$USER"; then
  echo "  🎉 Shell successfully changed to zsh."
else
  echo "  ⚠️  Failed to change shell to zsh."
fi
{{ end -}}

echo "✅ Login shell configuration complete."
