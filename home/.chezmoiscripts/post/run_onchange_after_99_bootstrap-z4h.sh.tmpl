{{- if not .host.interactive -}}
{{- includeTemplate "base/headers/script" (dict "root" .) -}}

command -v script >/dev/null 2>&1 || {
  echo "❌ z4h bootstrap requires the 'script' command to allocate a PTY." >&2
  exit 1
}

echo "🐚 Initializing Zsh with zsh4humans (z4h)..."
echo "  ↳ This will finalize the shell environment and may take a moment."
if script -q -c true /dev/null 2>/dev/null; then
  exec script -q -c 'env Z4H_BOOTSTRAPPING=1 _CHEZMOI_Z4H_BOOTSTRAP=1 zsh -i' /dev/null
else
  exec script -qe /dev/null env Z4H_BOOTSTRAPPING=1 _CHEZMOI_Z4H_BOOTSTRAP=1 zsh -i
fi

{{- end -}}
