{{- /* chezmoi:modify-template */ -}}
Include {{ .host.home }}/.config/ssh/config

{{- $stdin := get .chezmoi "stdin" | default "" -}}
{{- if regexMatch "(?m)^#### dotfiles:unmodified" $stdin }}
{{ regexFind "(?s)#### dotfiles:unmodified.*" $stdin }}
{{- else }}
{{ print "#### dotfiles:unmodified\n" }}
{{- end -}}
