{{- /* format/completions/external — Outputs .chezmoiexternal.toml entries for raw completions.
  Args (dict): completions — dict of id → completion info.
  Only processes entries with a repo key (skips generate-based and boolean completions). */ -}}
{{- $completions := .completions -}}
{{- range $id := sortAlpha (keys $completions) }}
    {{- $comp := index $completions $id }}
    {{- if index $comp "repo" }}
{{ includeTemplate "common/github/raw" (dict
    "target" (printf "_%s" $id)
    "repo"   (index $comp "repo")
    "source" (index $comp "path")) }}
    {{- end }}
{{- end }}
