{{- /* format/test — Outputs Bats test cases with auto-generated tags.
  Args (dict): packages — dict of id → package info. */ -}}
{{- $packages := .packages -}}
{{- range $id := sortAlpha (keys $packages) }}
    {{- $pkg := index $packages $id }}
    {{- $name := index $pkg "package" }}
    {{- $version := index $pkg "pin" }}
    {{- $toolchain := index $pkg "toolchain" }}
    {{- $manager := index $pkg "manager" }}
    {{- $suiteTag := "suite:packages" -}}
    {{- if eq $manager "system" -}}
    {{-   $suiteTag = "suite:system-packages" -}}
    {{- else if eq $manager "mise" -}}
    {{-   $suiteTag = "suite:mise-packages" -}}
    {{- else if eq $manager "helm" -}}
    {{-   $suiteTag = "suite:helm-plugins" -}}
    {{- else if eq $manager "krew" -}}
    {{-   $suiteTag = "suite:krew-plugins" -}}
    {{- end -}}
    {{- $tags := list $suiteTag "suite:packages" (printf "mgr:%s" $manager) (printf "toolchain:%s" $toolchain) (printf "pkg:%s" $id) -}}

# bats test_tags={{ $tags | join "," }}
@test "{{ $id }}{{ if $version }} ({{ $version }}){{ end }}" {
    {{- if index $pkg "test" }}
    run {{ index $pkg "test" }}
    assert_success
    {{- else }}
    skip "no test defined"
    {{- end }}
}

{{ end -}}
