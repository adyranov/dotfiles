{{- /* render — Package/completion orchestrator.
  Merges layered packages for enabled toolchains, applies
  disabled/os/arch filtering, then dispatches to a format subtemplate.

  Args (dict):
    root            — template data root (required)
    mode            — "packages" (default) | "completions"
    render          — format subtemplate path relative to common/packages/format/
                      packages: "install" (default) | "mise" | "test"
                      completions: "completions/external" | "completions/script" | "completions/ignore"
    packageManager  — packages mode filter: "system" (default) | "mise" | "helm" | "krew"
    compDir         — completions/script mode: destination directory path
*/ -}}
{{- $root := .root -}}
{{- $mode := index . "mode" | default "packages" -}}
{{- $render := index . "render" | default "install" -}}
{{- $packageManager := index . "packageManager" | default "system" -}}
{{- $compDir := index . "compDir" | default "" -}}
{{- $distroId := $root.host.distro.id -}}
{{- $arch := $root.host.arch -}}
{{- $result := dict -}}

{{- /* Build the list of toolchains enabled for this host (always include core). */ -}}
{{- $enabledToolchains := list "core" -}}
{{- range $toolName, $enabled := $root.toolchains }}
    {{- if $enabled }}
        {{- $enabledToolchains = append $enabledToolchains $toolName -}}
    {{- end }}
{{- end }}

{{- $osPackageLayers := index $root.packages "os" | default dict -}}
{{- $osPackages := index $osPackageLayers $distroId | default dict -}}
{{- $profileKey := "" -}}{{- if hasKey $root.host "profile" -}}{{- $profileKey = $root.host.profile -}}{{- end -}}
{{- $profilePackageLayers := index $root.packages "profile" | default dict -}}
{{- $profilePackages := index $profilePackageLayers $profileKey | default dict -}}
{{- $basePackages := index $root.packages "base" | default dict -}}

{{- /* Render base, OS-specific, and profile packages for every enabled toolchain. */ -}}
{{- range $i, $toolName := $enabledToolchains }}
    {{- $packages := includeTemplate "common/helpers/load-layered-section" (dict "root" $root "section" (printf "packages.%s" $toolName)) | mustFromJson -}}
    {{- $baseLayer := index $basePackages $toolName | default dict -}}
    {{- $osLayer := index $osPackages $toolName | default dict -}}
    {{- $profileLayer := index $profilePackages $toolName | default dict -}}
    {{- range $j, $id := sortAlpha (keys $packages) }}
        {{- $pkg := index $packages $id | default dict -}}
        {{- $basePkg := index $baseLayer $id | default dict -}}
        {{- $osPkg := index $osLayer $id | default dict -}}
        {{- $profilePkg := index $profileLayer $id | default dict -}}
        {{- $override := $osPkg | merge $profilePkg -}}

        {{- $rawComp := index $pkg "completion" | default "" -}}
        {{- /* In completions mode, skip packages without completion metadata. */ -}}
        {{- if and (eq $mode "completions") (not $rawComp) -}}{{- continue -}}{{- end -}}

        {{- $pkgOs := index $pkg "os" | default "" -}}
        {{- if and $pkgOs (ne $pkgOs $distroId) -}}{{- continue -}}{{- end -}}

        {{- $pkgDisabled := index $pkg "disabled" | default false -}}
        {{- $disabled := false -}}
        {{- if kindIs "string" $pkgDisabled -}}
            {{- if and ($pkgDisabled | contains "headless") (not $root.host.interactive) -}}
                {{- $disabled = true -}}
            {{- end -}}
            {{- if and ($pkgDisabled | contains "restricted") $root.host.restricted -}}
                {{- $disabled = true -}}
            {{- end -}}
            {{- if $pkgDisabled | contains $root.host.type -}}
                {{- $disabled = true -}}
            {{- end -}}
        {{- else if kindIs "bool" $pkgDisabled -}}
            {{- $disabled = $pkgDisabled -}}
        {{- end }}
        {{- if $disabled -}} {{- continue -}} {{- end }}

        {{- $pkgExcludeArch := index $pkg "exclude_arch" | default list -}}
        {{- $archExcluded := false -}}
        {{- range $j, $a := $pkgExcludeArch }}
            {{- if eq $arch $a -}}
                {{- $archExcluded = true -}}
            {{- end -}}
        {{- end }}
        {{- if $archExcluded -}} {{- continue -}} {{- end }}

        {{- /* ── Collect based on mode ── */ -}}
        {{- if eq $mode "completions" -}}
            {{- $bin := printf "%s" (index $pkg "bin" | default $id) -}}
            {{- $versionCmd := printf "%s --version" $bin -}}
            {{- if hasKey $pkg "version" -}}
                {{- $versionCmd = printf "%s" (index $pkg "version") -}}
            {{- end -}}
            {{- $comp := dict -}}
            {{- if kindIs "bool" $rawComp -}}
                {{- $comp = dict "generate" true "bin" $bin "version" $versionCmd -}}
            {{- else -}}
                {{- $comp = $rawComp -}}
                {{- $_ := set $comp "bin" $bin -}}
                {{- $_ := set $comp "version" $versionCmd -}}
            {{- end -}}
            {{- $_ := set $result $id $comp -}}
        {{- else -}}
            {{- $pkgMgr := printf "%s" (index $pkg "manager" | default "system") -}}
            {{- /* When an override changes the manager, reset package to key (package is manager-specific). */ -}}
            {{- $overrideMgr := index $override "manager" -}}
            {{- $baseMgr := index $basePkg "manager" | default "system" -}}
            {{- $mgrChanged := and $overrideMgr (ne (printf "%s" $overrideMgr) (printf "%s" $baseMgr)) -}}
            {{- $pkgName := printf "%s" (index $pkg "package" | default $id) -}}
            {{- if and $mgrChanged (not (hasKey $override "package")) -}}
                {{- $pkgName = $id -}}
            {{- end -}}
            {{- $pkgPin := printf "%s" (index $pkg "pin" | default "") -}}
            {{- $pkgBin := printf "%s" (index $pkg "bin" | default $id) -}}
            {{- $pkgPlatforms := index $pkg "platforms" | default dict -}}

            {{- /* Krew convention: strip kubectl- prefix for package, use "kubectl <plugin>" for bin. */ -}}
            {{- if eq $pkgMgr "krew" -}}
                {{- if not (hasKey $pkg "package") -}}
                    {{- $pkgName = trimPrefix "kubectl-" $id -}}
                {{- end -}}
                {{- if not (hasKey $pkg "bin") -}}
                    {{- $pkgBin = printf "kubectl %s" (trimPrefix "kubectl-" $id) -}}
                {{- end -}}
            {{- end -}}

            {{- /* Derive version command: explicit > krew convention (<bin> --help) > default (<bin> --version). */ -}}
            {{- $pkgVersion := printf "%s --version" $pkgBin -}}
            {{- if eq $pkgMgr "krew" -}}
                {{- $pkgVersion = printf "%s --help" $pkgBin -}}
            {{- end -}}
            {{- if hasKey $pkg "version" -}}
                {{- $pkgVersion = printf "%s" (index $pkg "version") -}}
            {{- end -}}

            {{- /* Derive test: explicit > version command. test=false disables. */ -}}
            {{- $pkgTest := $pkgVersion -}}
            {{- if hasKey $pkg "test" -}}
                {{- $rawTest := index $pkg "test" -}}
                {{- if kindIs "bool" $rawTest -}}
                    {{- if not $rawTest -}}{{- $pkgTest = "" -}}{{- end -}}
                {{- else -}}
                    {{- $pkgTest = printf "%s" $rawTest -}}
                {{- end -}}
            {{- end -}}

            {{- if eq $pkgMgr $packageManager -}}
                {{- $_ := set $result $id (dict
                    "id" $id
                    "manager" $pkgMgr
                    "package" $pkgName
                    "pin" $pkgPin
                    "version" $pkgVersion
                    "test" $pkgTest
                    "platforms" $pkgPlatforms
                    "toolchain" $toolName
                ) -}}
            {{- end }}
        {{- end -}}
    {{- end }}
{{- end }}

{{- /* Dispatch to the requested format subtemplate. */ -}}
{{- if eq $mode "completions" -}}
    {{- includeTemplate (printf "common/packages/format/%s" $render) (dict "completions" $result "compDir" $compDir) -}}
{{- else -}}
    {{- includeTemplate (printf "common/packages/format/%s" $render) (dict "packages" $result) -}}
{{- end -}}
