{{- /*
  Resolves the subagent→model map from pi.subagents × ai.models.

  Input: .root (chezmoi data root)
  Output: JSON dict of agentName → {model, thinking, fallbackModels?}
  where model is "provider/model" when provider is set.
*/ -}}
{{- $pi := includeTemplate "common/helpers/load-layered-section" (dict "root" .root "section" "ai.agents.pi" "required" true) | mustFromJson -}}
{{- $models := includeTemplate "common/helpers/load-layered-section" (dict "root" .root "section" "ai.models" "required" true) | mustFromJson -}}
{{- $result := dict -}}
{{- range $category, $agents := $pi.subagents -}}
{{-   $route := index $models $category -}}
{{-   $model := $route.model -}}
{{-   if hasKey $route "provider" -}}
{{-     $model = printf "%s/%s" $route.provider $route.model -}}
{{-   end -}}
{{-   $config := dict "model" $model "thinking" $route.thinking -}}
{{-   if hasKey $route "fallback_models" -}}
{{-     $_ := set $config "fallbackModels" $route.fallback_models -}}
{{-   end -}}
{{-   range $agent := $agents -}}
{{-     $result = merge $result (dict $agent $config) -}}
{{-   end -}}
{{- end -}}
{{- $result | toJson -}}
