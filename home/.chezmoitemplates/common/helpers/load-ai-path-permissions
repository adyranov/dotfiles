{{- /*
  Loads shared AI path permission policy.

  ai.permissions.paths.deny contains exact deny patterns rendered as-is.
  ai.permissions.paths.allow_read contains narrow read-only exceptions.
  Home paths should be written explicitly with ~/ in data.
*/ -}}
{{- $root := .root -}}
{{- $permissions := includeTemplate "common/helpers/load-layered-section" (dict "root" $root "section" "ai.permissions" "required" true) | mustFromJson -}}
{{- $paths := $permissions.paths | default dict -}}
{{- dict
  "allow_read" (index $paths "allow_read" | default list | uniq | sortAlpha)
  "allow_write" (index $paths "allow_write" | default list | uniq | sortAlpha)
  "deny" (index $paths "deny" | default list | uniq | sortAlpha)
| toJson -}}
