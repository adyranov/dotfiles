{{- /* base/packages/collect-policies — Merged bash command policy for enabled packages.

  Walks layered packages via `base/packages/walk`, picks the per-package
  `policy.deny` lists, and emits a single merged JSON document for consumers
  like greywall and the pi permission system.

  Args (dict):
    root — template data root (required)

  Output: JSON {"deny": [...]}, list sorted and uniq'd.
*/ -}}
{{- $root := .root -}}
{{- $entries := includeTemplate "base/packages/walk" (dict "root" $root) | mustFromJson -}}
{{- $deny := list -}}
{{- range $entry := $entries -}}
{{-   $policy := index $entry.pkg "policy" | default dict -}}
{{-   range $pattern := index $policy "deny" | default list -}}
{{-     $deny = append $deny $pattern -}}
{{-   end -}}
{{- end -}}
{{- dict "deny" ($deny | uniq | sortAlpha) | toJson -}}
