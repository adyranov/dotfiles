
echo "🛠️ Updating pacman DB and installing packages…"
{{- if or (eq .host.type "ephemeral") .host.interactive }}
sudo pacman -Syu --noconfirm --needed {{ includeTemplate "common/helpers/render-packages" (dict "root" .) }}
{{- else }}
sudo pacman -Sy --noconfirm
sudo pacman -S --noconfirm --needed {{ includeTemplate "common/helpers/render-packages" (dict "root" .) }}
{{- end }}
echo "✅ pacman packages ensured."
