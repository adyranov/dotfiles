# Post-init bootstrap (before-phase): refreshes Homebrew after .init.sh installed it.
# Package installation is handled by os/darwin/install via brew bundle.

eval $({{ .brew.path }} shellenv)
{{- includeTemplate "common/helpers/sudo-keep-alive" . }}
echo "🍺 Updating Homebrew…"
brew update
{{- if or (eq .host.type "ephemeral") .host.interactive }}
echo "📦 Upgrading formulae…"
brew upgrade
echo "🧰 Upgrading casks…"
brew upgrade --cask --greedy
echo "🧹 Cleaning up…"
brew cleanup
{{- end }}
echo "✅ Homebrew updated."
