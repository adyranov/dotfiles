{{- $brew := includeTemplate "base/helpers/load-section" (dict "root" . "section" "brew") | mustFromJson -}}

{{- $taps := index $brew "taps" | default list -}}
{{- $brews := concat (splitList " " (includeTemplate "base/packages/collect-packages" (dict "root" . "manager" "system" "format" "install"))) (index $brew "brews" | default list) -}}
{{- $casks := index $brew "casks" | default list -}}
{{- $mas := index $brew "mas" | default list -}}
{{- range $taps -}}
{{- if kindIs "map" . -}}
{{- if .url -}}
{{- printf "tap \"%s\", \"%s\"\n" .name .url -}}
{{- else -}}
{{- printf "tap \"%s\"\n" .name -}}
{{- end -}}
{{- else -}}
{{- printf "tap \"%s\"\n" . -}}
{{- end -}}
{{- end -}}
{{ range ($brews | sortAlpha | uniq) }}
brew "{{ . }}"
{{- end }}
{{- if .host.interactive -}}
{{ range ($casks | sortAlpha | uniq) }}
cask "{{ . }}"
{{- end }}
{{ range ($mas | uniq) }}
mas "{{ .name }}", id: {{ printf "%.0f" .id }}
{{- end }}
{{- end }}
