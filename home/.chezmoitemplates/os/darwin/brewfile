{{- $brew := includeTemplate "common/helpers/load-layered-section" (dict "root" . "section" "brew") | mustFromJson -}}

{{- $taps := index $brew "taps" | default list -}}
{{- $brews := concat (splitList " " (includeTemplate "common/packages/render" (dict "root" .))) (index $brew "brews" | default list) -}}
{{- $casks := index $brew "casks" | default list -}}
{{- $mas := index $brew "mas" | default list -}}

{{- range ($taps | sortAlpha | uniq) }}
tap "{{ . }}"
{{- end }}
{{ range ($brews | sortAlpha | uniq) }}
brew "{{ . }}"
{{- end }}
{{- if .host.interactive -}}
{{ range ($casks | sortAlpha | uniq) }}
cask "{{ . }}"
{{- end }}
{{ range ($mas | uniq) }}
mas "{{ .name }}", id: {{ printf "%.0f" .id }}
{{- end }}
{{- end }}
